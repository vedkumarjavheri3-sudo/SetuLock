# SetuSeva Backend Environment Variables Template
# DO NOT COMMIT ACTUAL .env FILES

# Server Configuration
PORT=3000
NODE_ENV=development # development, staging, production
API_VERSION=v1

# Security & Encryption
# Master key must be securely generated (e.g., via `openssl rand -hex 32`)
ENCRYPTION_MASTER_KEY=your_secure_32_byte_hex_key_here
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=8h

# Supabase Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# CORS — Operator Portal URL
OPERATOR_PORTAL_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_GLOBAL_WINDOW_MS=60000 # 1 minute

# Notification Mode: 'email' (now) or 'sms' (future)
NOTIFICATION_MODE=email

# Email (Gmail SMTP) — used when NOTIFICATION_MODE=email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# SMS (MSG91) — used when NOTIFICATION_MODE=sms (future)
# MSG91_AUTH_KEY=your_msg91_auth_key
# MSG91_SENDER_ID=SETUSV

# ERASE Deletion Delay
ERASE_DELAY_DAYS=30

# Logging
LOG_LEVEL=info # debug, info, warn, error
